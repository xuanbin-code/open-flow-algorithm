<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="未命名"/>
        <attribute name="authors" value=""/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-06-11"/>
    </attributes>
    <function name="Main" type="" variable="">
        <parameters/>
        <body>
            <declare name="res" type="Integer" array="False" size=""/>
            <declare name="a" type="Integer" array="False" size=""/>
            <declare name="b" type="Integer" array="False" size=""/>
            <input variable="a"/>
            <input variable="b"/>
            <call expression="add(a, b)" result="res"/>
            <output expression="res" newline="True"/>
        </body>
    </function>
    <function name="add" type="Integer" variable="res">
        <parameters>
            <parameter name="x" type="Integer" array="False"/>
            <parameter name="y" type="Integer" array="False"/>
        </parameters>
        <body>
            <declare name="res" type="Integer" array="False" size="" tag="return"/>
            <declare name="x" type="Integer" array="False" size="" tag="parameter"/>
            <declare name="y" type="Integer" array="False" size="" tag="parameter"/>
            <assign variable="res" expression="x + y"/>
        </body>
    </function>
</flowgorithm>
