<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="Function Demo"/>
        <attribute name="authors" value=""/>
        <attribute name="about" value="Demonstrates calling a function, receiving its return value, and printing the result."/>
        <attribute name="saved" value="2026-06-15"/>
    </attributes>
    <function name="Main" type="" variable="">
        <parameters/>
        <body>
            <declare name="result" type="Integer" array="False" size=""/>
            <call expression="add(10, 20)" result="result"/>
            <output expression="&quot;add(10, 20) = &quot; &amp; result" newline="True"/>
        </body>
    </function>
    <function name="add" type="Integer" variable="sum">
        <parameters>
            <parameter name="a" type="Integer" array="False"/>
            <parameter name="b" type="Integer" array="False"/>
        </parameters>
        <body>
            <declare name="sum" type="Integer" array="False" size="" tag="return"/>
            <declare name="a" type="Integer" array="False" size="" tag="parameter"/>
            <declare name="b" type="Integer" array="False" size="" tag="parameter"/>
            <assign variable="sum" expression="a + b"/>
        </body>
    </function>
</flowgorithm>
