{
  "$schema": "https://raw.githubusercontent.com/nicklaus-dev/tauri-docs/refs/heads/v2/src/content/docs/_schema/config.schema.json",
  "productName": "FlowgorithmJS",
  "version": "0.1.0",
  "identifier": "com.flowgorithmjs.demo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Flowgorithm JS - 流程图",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
