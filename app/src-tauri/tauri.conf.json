{
  "$schema": "https://raw.githubusercontent.com/nicklaus-dev/tauri-docs/refs/heads/v2/src/content/docs/_schema/config.schema.json",
  "productName": "Open Flow Algorithm",
  "version": "0.1.0",
  "identifier": "com.openflowalgorithm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Open Flow Algorithm",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../python-backend": "python-backend"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xuanbin-code/open-flow-algorithm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGREFBRkQxNjM3QUY1MjcKUldRbjlYcGowYS9hbjFTekIxM3FyYTZQU2hzN1ZtTy9SMHVrZXRXeXhkbzFFRVZIaDF1VWJsRmwK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
